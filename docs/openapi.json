{
  "components": {
    "schemas": {
      "AdviceItemResponse": {
        "description": "One per-finding advice entry returned by ``GET /scans/{id}/advice``.",
        "properties": {
          "finding_id": {
            "title": "Finding Id",
            "type": "integer"
          },
          "message": {
            "title": "Message",
            "type": "string"
          },
          "remediation": {
            "title": "Remediation",
            "type": "string"
          },
          "resource_logical_id": {
            "title": "Resource Logical Id",
            "type": "string"
          },
          "rule_id": {
            "title": "Rule Id",
            "type": "string"
          },
          "severity": {
            "$ref": "#/components/schemas/cfn_auditor__models__finding__Severity"
          },
          "source": {
            "title": "Source",
            "type": "string"
          }
        },
        "required": [
          "finding_id",
          "rule_id",
          "severity",
          "resource_logical_id",
          "message",
          "remediation",
          "source"
        ],
        "title": "AdviceItemResponse",
        "type": "object"
      },
      "AdviceResponse": {
        "description": "Envelope returned by ``GET /scans/{id}/advice``.",
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/AdviceItemResponse"
            },
            "title": "Items",
            "type": "array"
          },
          "provider": {
            "title": "Provider",
            "type": "string"
          },
          "scan_id": {
            "title": "Scan Id",
            "type": "integer"
          }
        },
        "required": [
          "scan_id",
          "provider",
          "items"
        ],
        "title": "AdviceResponse",
        "type": "object"
      },
      "FindingResponse": {
        "description": "One persisted finding on a scan.",
        "properties": {
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "message": {
            "title": "Message",
            "type": "string"
          },
          "resource_logical_id": {
            "title": "Resource Logical Id",
            "type": "string"
          },
          "resource_type": {
            "title": "Resource Type",
            "type": "string"
          },
          "rule_id": {
            "title": "Rule Id",
            "type": "string"
          },
          "severity": {
            "$ref": "#/components/schemas/cfn_auditor__models__finding__Severity"
          }
        },
        "required": [
          "id",
          "rule_id",
          "severity",
          "resource_logical_id",
          "resource_type",
          "message"
        ],
        "title": "FindingResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "description": "Liveness response.",
        "properties": {
          "status": {
            "description": "Constant 'ok' for healthy.",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "RuleResponse": {
        "description": "Public metadata for a registered guardrail rule.\n\nMirrors the ``Rule`` class's class vars: ``id``, ``title``, ``severity``,\nand ``resource_types``. ``Rule`` does not currently carry a remediation\nstring (remediation lives on ``RuleFinding``), so it is not exposed here.",
        "properties": {
          "id": {
            "title": "Id",
            "type": "string"
          },
          "resource_types": {
            "description": "CloudFormation resource types the rule applies to, sorted.",
            "items": {
              "type": "string"
            },
            "title": "Resource Types",
            "type": "array"
          },
          "severity": {
            "$ref": "#/components/schemas/cfn_auditor__rules__severity__Severity"
          },
          "title": {
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "severity",
          "resource_types"
        ],
        "title": "RuleResponse",
        "type": "object"
      },
      "ScanCreateRequest": {
        "description": "JSON body for POST /scans.\n\nEither ``template`` (raw YAML/JSON content) is required. ``name`` is an\noptional caller-supplied label used in diagnostics; defaults to\n``template`` when absent.",
        "properties": {
          "name": {
            "default": "template",
            "description": "Label for the template.",
            "title": "Name",
            "type": "string"
          },
          "template": {
            "description": "Raw CloudFormation template content.",
            "minLength": 1,
            "title": "Template",
            "type": "string"
          }
        },
        "required": [
          "template"
        ],
        "title": "ScanCreateRequest",
        "type": "object"
      },
      "ScanDetailResponse": {
        "description": "Full scan response: summary fields + findings.",
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "critical_count": {
            "title": "Critical Count",
            "type": "integer"
          },
          "finding_count": {
            "title": "Finding Count",
            "type": "integer"
          },
          "findings": {
            "items": {
              "$ref": "#/components/schemas/FindingResponse"
            },
            "title": "Findings",
            "type": "array"
          },
          "high_count": {
            "title": "High Count",
            "type": "integer"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "info_count": {
            "title": "Info Count",
            "type": "integer"
          },
          "low_count": {
            "title": "Low Count",
            "type": "integer"
          },
          "medium_count": {
            "title": "Medium Count",
            "type": "integer"
          },
          "score": {
            "$ref": "#/components/schemas/ScoreResponse"
          },
          "status": {
            "$ref": "#/components/schemas/ScanStatus"
          },
          "template_name": {
            "title": "Template Name",
            "type": "string"
          }
        },
        "required": [
          "id",
          "created_at",
          "template_name",
          "status",
          "finding_count",
          "critical_count",
          "high_count",
          "medium_count",
          "low_count",
          "info_count",
          "score",
          "findings"
        ],
        "title": "ScanDetailResponse",
        "type": "object"
      },
      "ScanStatus": {
        "description": "Lifecycle state of a scan.",
        "enum": [
          "PENDING",
          "RUNNING",
          "SUCCEEDED",
          "FAILED"
        ],
        "title": "ScanStatus",
        "type": "string"
      },
      "ScanSummaryResponse": {
        "description": "Scan list-row: counters and computed scoring; no findings.",
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "critical_count": {
            "title": "Critical Count",
            "type": "integer"
          },
          "finding_count": {
            "title": "Finding Count",
            "type": "integer"
          },
          "high_count": {
            "title": "High Count",
            "type": "integer"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "info_count": {
            "title": "Info Count",
            "type": "integer"
          },
          "low_count": {
            "title": "Low Count",
            "type": "integer"
          },
          "medium_count": {
            "title": "Medium Count",
            "type": "integer"
          },
          "score": {
            "$ref": "#/components/schemas/ScoreResponse"
          },
          "status": {
            "$ref": "#/components/schemas/ScanStatus"
          },
          "template_name": {
            "title": "Template Name",
            "type": "string"
          }
        },
        "required": [
          "id",
          "created_at",
          "template_name",
          "status",
          "finding_count",
          "critical_count",
          "high_count",
          "medium_count",
          "low_count",
          "info_count",
          "score"
        ],
        "title": "ScanSummaryResponse",
        "type": "object"
      },
      "ScoreResponse": {
        "description": "Computed score / grade / pre-deploy gate.",
        "properties": {
          "grade": {
            "description": "Letter grade A/B/C/D/F.",
            "title": "Grade",
            "type": "string"
          },
          "passed": {
            "description": "Pre-deploy gate result; True when no CRITICAL findings.",
            "title": "Passed",
            "type": "boolean"
          },
          "score": {
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Score",
            "type": "integer"
          }
        },
        "required": [
          "score",
          "grade",
          "passed"
        ],
        "title": "ScoreResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "cfn_auditor__models__finding__Severity": {
        "description": "Severity of a guardrail violation.",
        "enum": [
          "CRITICAL",
          "HIGH",
          "MEDIUM",
          "LOW",
          "INFO"
        ],
        "title": "Severity",
        "type": "string"
      },
      "cfn_auditor__rules__severity__Severity": {
        "description": "Severity assigned to a rule finding. No numeric weights \u2014 that's scoring.",
        "enum": [
          "CRITICAL",
          "HIGH",
          "MEDIUM",
          "LOW"
        ],
        "title": "Severity",
        "type": "string"
      }
    }
  },
  "info": {
    "description": "Static-analysis security guardrail auditor for AWS CloudFormation templates. API-first; no live AWS calls.",
    "title": "CFN Security Auditor",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "description": "Return ``{\"status\": \"ok\"}``. Always 200 when the process is up.",
        "operationId": "get_health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Health",
        "tags": [
          "health"
        ]
      }
    },
    "/rules": {
      "get": {
        "description": "Return every registered rule's public metadata, in registration order.",
        "operationId": "list_rules_rules_get",
        "parameters": [
          {
            "in": "header",
            "name": "x-api-key",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/RuleResponse"
                  },
                  "title": "Response List Rules Rules Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Rules",
        "tags": [
          "rules"
        ]
      }
    },
    "/scans": {
      "get": {
        "description": "List persisted scans newest-first; deterministic secondary sort by id desc.",
        "operationId": "list_scans_scans_get",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 50,
              "maximum": 200,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "offset",
            "required": false,
            "schema": {
              "default": 0,
              "minimum": 0,
              "title": "Offset",
              "type": "integer"
            }
          },
          {
            "in": "header",
            "name": "x-api-key",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ScanSummaryResponse"
                  },
                  "title": "Response List Scans Scans Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Scans",
        "tags": [
          "scans"
        ]
      },
      "post": {
        "description": "Run a scan on the supplied template and return the persisted result.",
        "operationId": "create_scan_scans_post",
        "parameters": [
          {
            "in": "header",
            "name": "x-api-key",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScanCreateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScanDetailResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Create Scan",
        "tags": [
          "scans"
        ]
      }
    },
    "/scans/{scan_id}": {
      "get": {
        "description": "Return one scan with its findings and computed score.",
        "operationId": "get_scan_scans__scan_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "scan_id",
            "required": true,
            "schema": {
              "title": "Scan Id",
              "type": "integer"
            }
          },
          {
            "in": "header",
            "name": "x-api-key",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScanDetailResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Scan",
        "tags": [
          "scans"
        ]
      }
    },
    "/scans/{scan_id}/advice": {
      "get": {
        "description": "Return per-finding remediation advice from the active provider.\n\nCompute-on-read: nothing is persisted. The provider is selected by\n:func:`cfn_auditor.advisor.get_provider`; today that is always the\ndeterministic :class:`StaticRemediationProvider`. Detail messages name\nonly the scan id \u2014 never template content.",
        "operationId": "get_scan_advice_scans__scan_id__advice_get",
        "parameters": [
          {
            "in": "path",
            "name": "scan_id",
            "required": true,
            "schema": {
              "title": "Scan Id",
              "type": "integer"
            }
          },
          {
            "in": "header",
            "name": "x-api-key",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdviceResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Scan Advice",
        "tags": [
          "scans"
        ]
      }
    }
  }
}
